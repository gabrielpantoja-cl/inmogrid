generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// SUPABASE AUTH PATTERN
// id references auth.users.id (UUID managed by Supabase Auth)
// No NextAuth models (Account, Session, VerificationToken, User)
// ============================================================

model Profile {
  id              String          @id @db.Uuid
  username        String?         @unique
  fullName        String?         @map("full_name")
  avatarUrl       String?         @map("avatar_url")
  bio             String?
  profession      ProfessionType?
  company         String?
  phone           String?
  region          String?
  commune         String?
  website         String?
  linkedin        String?
  tagline         String?
  coverImageUrl   String?         @map("cover_image_url")
  location        String?
  identityTags    String[]        @default([]) @map("identity_tags")
  externalLinks   Json?           @map("external_links")
  isPublicProfile Boolean         @default(true) @map("is_public_profile")
  role            Role            @default(user)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  Post                            Post[]
  AuditLog                        AuditLog[]
  ChatMessage                     ChatMessage[]
  Event                           Event[]
  ProfessionalProfile             ProfessionalProfile?
  Connection_receiverIdToProfile  Connection[] @relation("Connection_receiverIdToProfile")
  Connection_requesterIdToProfile Connection[] @relation("Connection_requesterIdToProfile")

  @@map("degux_profiles")
}

// ============================================================
// COMMUNITY & NETWORKING
// ============================================================

model Connection {
  id          String           @id @default(cuid())
  requesterId String           @db.Uuid @map("requester_id")
  receiverId  String           @db.Uuid @map("receiver_id")
  status      ConnectionStatus @default(pending)
  message     String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  requester   Profile          @relation("Connection_requesterIdToProfile", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    Profile          @relation("Connection_receiverIdToProfile", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([receiverId, status])
  @@index([requesterId, status])
  @@map("degux_connections")
}

// ============================================================
// CONTENT
// ============================================================

model Post {
  id            String    @id @default(cuid())
  userId        String    @db.Uuid @map("user_id")
  title         String
  slug          String    @unique
  content       String
  excerpt       String?
  coverImageUrl String?   @map("cover_image_url")
  published     Boolean   @default(false)
  publishedAt   DateTime? @map("published_at")
  tags          String[]  @default([])
  readTime      Int?      @map("read_time")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  author        Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([userId, published])
  @@map("degux_posts")
}

// ============================================================
// EVENTS
// ============================================================

model Event {
  id              String        @id @default(cuid())
  title           String
  description     String
  organizerName   String        @map("organizer_name")
  organizerType   OrganizerType @map("organizer_type")
  eventType       EventType     @map("event_type")
  startDate       DateTime      @map("start_date")
  endDate         DateTime?     @map("end_date")
  location        String?
  isOnline        Boolean       @default(false) @map("is_online")
  onlineUrl       String?       @map("online_url")
  coverImageUrl   String?       @map("cover_image_url")
  registrationUrl String?       @map("registration_url")
  isFree          Boolean       @default(true) @map("is_free")
  isCommercial    Boolean       @default(false) @map("is_commercial")
  isPaid          Boolean       @default(false) @map("is_paid")
  price           Float?
  status          EventStatus   @default(PENDING)
  publishedAt     DateTime?     @map("published_at")
  region          String?
  commune         String?
  userId          String?       @db.Uuid @map("user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  author          Profile?      @relation(fields: [userId], references: [id])

  @@index([status, startDate])
  @@index([region, status])
  @@index([isCommercial, status])
  @@map("degux_events")
}

// ============================================================
// PROFESSIONAL DIRECTORY
// ============================================================

model ProfessionalProfile {
  id              String    @id @default(cuid())
  userId          String    @unique @db.Uuid @map("user_id")
  specialty       String[]  @default([])
  certifications  String[]  @default([])
  regions         String[]  @default([])
  yearsExperience Int?      @map("years_experience")
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  profile         Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("degux_professional_profiles")
}

// ============================================================
// SYSTEM
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  profile   Profile  @relation(fields: [userId], references: [id])

  @@map("degux_audit_logs")
}

model ChatMessage {
  id        String      @id @default(cuid())
  userId    String      @db.Uuid @map("user_id")
  role      MessageRole
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  profile   Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("degux_chat_messages")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  user
  admin
  superadmin
}

enum ProfessionType {
  TASADOR_PERITO
  PERITO_JUDICIAL
  CORREDOR_PROPIEDADES
  ADMINISTRADOR_PROP
  ABOGADO_INMOBILIARIO
  ARQUITECTO
  INGENIERO_CIVIL
  ACADEMICO
  FUNCIONARIO_PUBLICO
  INVERSIONISTA
  PROPIETARIO
  OTRO
}

enum ConnectionStatus {
  pending
  accepted
  rejected
  blocked
}

enum MessageRole {
  user
  bot
}

enum EventStatus {
  PENDING
  PUBLISHED
  REJECTED
  EXPIRED
}

enum EventType {
  TALLER
  SEMINARIO
  CHARLA
  CURSO
  OPEN_HOUSE
  LANZAMIENTO
}

enum OrganizerType {
  MUNICIPAL
  UNIVERSITARIO
  GREMIAL
  COMERCIAL
}
