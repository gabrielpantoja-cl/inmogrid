# =========================================
# 🗄️ BASE DE DATOS POSTGRESQL - ARQUITECTURA V2
# =========================================
# NUEVO (Nov 2025): PostgreSQL dedicado para degux.cl
# Container: degux-db (separado de n8n-db)
# Base de datos: degux_core
# Puerto externo VPS: 5433
# Puerto interno Docker: 5432

# ✅ PRODUCCIÓN (Docker container degux-db)
# Usado por degux-web dentro de Docker network
POSTGRES_PRISMA_URL="postgresql://degux_user:PASSWORD@degux-db:5432/degux_core?schema=public&connect_timeout=10"
POSTGRES_URL="postgresql://degux_user:PASSWORD@degux-db:5432/degux_core"

# 🔧 DESARROLLO LOCAL (conexión directa al VPS)
# Requiere SSH tunnel: npm run dev:tunnel
# POSTGRES_PRISMA_URL="postgresql://degux_user:PASSWORD@167.172.251.27:5433/degux_core?schema=public&sslmode=require"

# 💻 DESARROLLO LOCAL (PostgreSQL local)
# POSTGRES_PRISMA_URL="postgresql://degux_user:PASSWORD@localhost:5432/degux_dev?schema=public"

# =========================================
# 🔐 NEXTAUTH.JS - AUTENTICACIÓN
# =========================================
# Genera un secreto seguro: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"

# URL base de la aplicación, usada para generar URLs absolutas (cambia según el ambiente)
# Desarrollo:
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Producción en VPS:
# NEXT_PUBLIC_BASE_URL="https://degux.cl"

# Debug (solo desarrollo)
NEXTAUTH_DEBUG="true"

# =========================================
# 🔑 GOOGLE OAUTH 2.0
# =========================================
# Configurar en: https://console.cloud.google.com/apis/credentials
# URLs de callback autorizadas:
# - Desarrollo: http://localhost:3000/api/auth/callback/google
# - Producción: https://degux.cl/api/auth/callback/google

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ✅ DEBUG - Solo en desarrollo
# Habilitar solo en desarrollo para debugging
NEXTAUTH_DEBUG="true"

# Variables opcionales
# Para enviar correo cuando el usuario se autentica por primera vez
# y cuando elimina cuenta
# EMAIL_USER=tu_correo@gmail.com
# EMAIL_PASS=tu_contraseña

# OpenAI para el chatbot
# OPENAI_API_KEY=sk-...

# =========================================
# 🗺️ GOOGLE MAPS API (GEOCODING)
# =========================================
# Para geocodificación de direcciones
# Configurar en: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# =========================================
# 🔗 N8N WEBHOOKS (OPCIONAL)
# =========================================
# Para importación masiva de datos desde N8N
N8N_WEBHOOK_URL="http://167.172.251.27:5678/webhook/bulk-import"
N8N_WEBHOOK_SECRET="your_n8n_webhook_secret"

# =========================================
# 📦 REPOSITORIO GITHUB
# =========================================
NEXT_PUBLIC_GITHUB_REPO_OWNER="gabrielpantoja-cl"
NEXT_PUBLIC_GITHUB_REPO_NAME="degux.cl"
NEXT_PUBLIC_GITHUB_REPO_URL="https://github.com/gabrielpantoja-cl/degux.cl"

# Token de GitHub (opcional, para mayor rate limit en API)
# Obtener en: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# 🌐 VPS INFRASTRUCTURE
# =========================================
IP_VPS="167.172.251.27"
URL_PORTAINER="167.172.251.27:9443"
URL_N8N="n8n.gabrielpantoja.cl"
