# =========================================
# ⚠️  SOLO TEMPLATE — NO PEGAR VALORES REALES
# =========================================
# Este archivo es un TEMPLATE público que viaja en el repo opensource.
# Nunca escribas aquí secretos reales (OAuth client secrets, passwords
# de DB, API keys, tokens). Usá `.env.local` para los valores reales —
# ese archivo está en `.gitignore` y nunca se commitea.
#
# Si encontrás un valor real acá, es un bug — reportalo o rotalo. Ver
# `infra/privado/inmogrid.cl/secret-exposure-incident-2026-04-11.md`
# para el post-mortem del último incidente.

# =========================================
# 🗄️ BASE DE DATOS POSTGRESQL - ARQUITECTURA V2
# =========================================
# NUEVO (Nov 2025): PostgreSQL dedicado para inmogrid.cl
# Container: inmogrid-db (separado de n8n-db)
# Base de datos: inmogrid_core
# Puerto externo VPS: 5433
# Puerto interno Docker: 5432

# ✅ PRODUCCIÓN (Docker container inmogrid-db)
# Usado por inmogrid-web dentro de Docker network
POSTGRES_PRISMA_URL="postgresql://inmogrid_user:PASSWORD@inmogrid-db:5432/inmogrid_core?schema=public&connect_timeout=10"
POSTGRES_URL="postgresql://inmogrid_user:PASSWORD@inmogrid-db:5432/inmogrid_core"

# 🔧 DESARROLLO LOCAL (conexión directa al VPS)
# Requiere SSH tunnel: npm run dev:tunnel
# POSTGRES_PRISMA_URL="postgresql://inmogrid_user:PASSWORD@VPS_IP_REDACTED:5433/inmogrid_core?schema=public&sslmode=require"

# 💻 DESARROLLO LOCAL (PostgreSQL local)
# POSTGRES_PRISMA_URL="postgresql://inmogrid_user:PASSWORD@localhost:5432/inmogrid_dev?schema=public"

# =========================================
# 🔐 NEXTAUTH.JS - AUTENTICACIÓN
# =========================================
# Genera un secreto seguro: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"

# URL de NextAuth (IMPORTANTE: debe coincidir con el dominio real)
# Desarrollo local:
# NEXTAUTH_URL="http://localhost:3000"
# Producción VPS:
NEXTAUTH_URL="https://inmogrid.cl"

# URL base de la aplicación, usada para generar URLs absolutas (cambia según el ambiente)
# Desarrollo:
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Producción en VPS:
NEXT_PUBLIC_BASE_URL="https://inmogrid.cl"

# Debug (solo desarrollo, comentar en producción)
# NEXTAUTH_DEBUG="true"

# =========================================
# 🔑 GOOGLE OAUTH 2.0
# =========================================
# Configurar en: https://console.cloud.google.com/apis/credentials
# Proyecto: inmogrid-cl
# Cliente OAuth 2.0: GCP_PROJECT_NUMBER_REDACTED-b3utu9es3bfpoovilhqdhdtr0hm3378s.apps.googleusercontent.com
#
# URLs de callback autorizadas (AMBAS configuradas en Google Cloud Console):
# - Desarrollo: http://localhost:3000/api/auth/callback/google
# - Producción: https://inmogrid.cl/api/auth/callback/google
#
# Orígenes JavaScript autorizados:
# - Desarrollo: http://localhost:3000
# - Producción: https://inmogrid.cl

GOOGLE_CLIENT_ID="GCP_PROJECT_NUMBER_REDACTED-b3utu9es3bfpoovilhqdhdtr0hm3378s.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"

# Variables opcionales
# Para enviar correo cuando el usuario se autentica por primera vez
# y cuando elimina cuenta
# EMAIL_USER=tu_correo@gmail.com
# EMAIL_PASS=tu_contraseña

# OpenAI para el chatbot
# OPENAI_API_KEY=sk-...

# =========================================
# 🗺️ GOOGLE MAPS API (GEOCODING)
# =========================================
# Para geocodificación de direcciones
# Configurar en: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# =========================================
# 🔗 N8N WEBHOOKS (OPCIONAL)
# =========================================
# Para importación masiva de datos desde N8N
N8N_WEBHOOK_URL="http://VPS_IP_REDACTED:5678/webhook/bulk-import"
N8N_WEBHOOK_SECRET="your_n8n_webhook_secret"

# Login notification webhook — fires once per OAuth exchange from
# src/app/auth/callback/route.ts. Delivers a Resend email via the
# INMOGRID-LOGIN-NOTIFY workflow. Leave unset to disable notifications.
N8N_LOGIN_WEBHOOK_URL="https://N8N_HOST_REDACTED/webhook/inmogrid-login"

# =========================================
# 📦 REPOSITORIO GITHUB
# =========================================
NEXT_PUBLIC_GITHUB_REPO_OWNER="gabrielpantoja-cl"
NEXT_PUBLIC_GITHUB_REPO_NAME="inmogrid"
NEXT_PUBLIC_GITHUB_REPO_URL="https://github.com/gabrielpantoja-cl/inmogrid"

# Token de GitHub (opcional, para mayor rate limit en API)
# Obtener en: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# 🌐 VPS INFRASTRUCTURE
# =========================================
IP_VPS="VPS_IP_REDACTED"
URL_PORTAINER="VPS_IP_REDACTED:9443"
URL_N8N="N8N_HOST_REDACTED"
